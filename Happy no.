class Solution {
    public boolean isHappy(int n) {
        while(n!=1 && n!=4){
            n = getNext(n);
        }
        return n==1;
    }
    private int getNext(int num){
        int sum=0;
        while(num>0){
            int digit = num % 10;
            sum = sum + digit*digit;
            num=num/10;
        }
        return sum;
    }
}
